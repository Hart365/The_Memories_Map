# Backend
/backend/vendor/
/backend/.env
/backend/.env.backup
/backend/storage/app/
/backend/storage/framework/cache/
/backend/storage/framework/sessions/
/backend/storage/framework/testing/
/backend/storage/framework/views/
/backend/storage/logs/
/backend/bootstrap/cache/*.php

# Frontend
/frontend/node_modules/
/frontend/dist/

# Media (never commit media files)
/media/

# Docker
/docker/db_data/

# OS
.DS_Store
Thumbs.db
*.swp
*~

# IDE
.vscode/settings.json
.idea/
*.code-workspace

# Compiled frontend assets (output to backend/public by Vite build)
/backend/public/assets/
/backend/public/index.html
!/backend/public/.gitkeep

# Local release archives and logs (built by local scripts)
/deploy/releases/*.zip
/deploy/releases/*.log
!/deploy/releases/.gitkeep
